<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="@color/fondo"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER  -->
    <LinearLayout
        android:id="@+id/header"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="D&amp;D Companion"
            android:textColor="@color/dorado"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="TU AVENTURA, SIEMPRE CONTIGO"
            android:textColor="@color/dorado_claro"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dorado"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomMenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- PERSONAJE -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:background="@drawable/seccion_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="TU PERSONAJE" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="›" android:textColor="@color/dorado" android:textSize="18sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp"/>

                <!-- Columna IZQ -->
                <LinearLayout android:orientation="horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <!-- Retrato -->
                    <LinearLayout
                        android:layout_width="76dp"
                        android:layout_height="130dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/avatar_bg"
                        android:gravity="center">
                        <TextView android:text="⚔" android:textSize="30sp"
                            android:textColor="@color/dorado"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Columna DER -->
                    <LinearLayout android:orientation="vertical"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1">

                        <!-- Nombre y descripción -->
                        <TextView android:id="@+id/txtNombrePersonaje" android:text="Arannis"
                            android:textColor="@color/texto" android:textSize="17sp"
                            android:textStyle="bold" android:fontFamily="serif"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Elfo de los Bosques"
                            android:textColor="@color/texto_secundario" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Mago Nivel 5"
                            android:textColor="@color/texto_secundario" android:textSize="11sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Caótico Neutral"
                            android:textColor="@color/texto_secundario" android:textSize="11sp"
                            android:layout_marginBottom="8dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                        <!-- ESCUDOS -->
                        <LinearLayout android:orientation="horizontal"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <!-- Escudo CA -->
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="56dp"
                                android:layout_weight="1" android:layout_marginEnd="4dp"
                                android:background="@drawable/shield_bg">
                                <TextView android:text="CA" android:textColor="@color/dorado_claro"
                                    android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="13" android:textColor="@color/texto"
                                    android:textSize="17sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <!-- Escudo PG -->
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="56dp"
                                android:layout_weight="1" android:layout_marginEnd="4dp"
                                android:background="@drawable/shield_bg">
                                <TextView android:text="PG" android:textColor="@color/dorado_claro"
                                    android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="31/31" android:textColor="@color/texto"
                                    android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <!-- Escudo INIC -->
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="56dp"
                                android:layout_weight="1"
                                android:background="@drawable/shield_bg">
                                <TextView android:text="INIC." android:textColor="@color/dorado_claro"
                                    android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="+2" android:textColor="@color/texto"
                                    android:textSize="17sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ATRIBUTOS -->
                        <LinearLayout android:orientation="horizontal"
                            android:layout_width="match_parent" android:layout_height="wrap_content">

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <TextView android:text="FUE" android:textColor="@color/dorado_claro" android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="8" android:textColor="@color/texto" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="(-1)" android:textColor="@color/texto_secundario" android:textSize="8sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <TextView android:text="DES" android:textColor="@color/dorado_claro" android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="14" android:textColor="@color/texto" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="(+2)" android:textColor="@color/texto_secundario" android:textSize="8sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <TextView android:text="CON" android:textColor="@color/dorado_claro" android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="14" android:textColor="@color/texto" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="(+2)" android:textColor="@color/texto_secundario" android:textSize="8sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <TextView android:text="INT" android:textColor="@color/dorado_claro" android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="18" android:textColor="@color/texto" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="(+4)" android:textColor="@color/texto_secundario" android:textSize="8sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <TextView android:text="SAB" android:textColor="@color/dorado_claro" android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="12" android:textColor="@color/texto" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="(+1)" android:textColor="@color/texto_secundario" android:textSize="8sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <TextView android:text="CAR" android:textColor="@color/dorado_claro" android:textSize="7sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="10" android:textColor="@color/texto" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:text="(+0)" android:textColor="@color/texto_secundario" android:textSize="8sp"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- MISIONES ACTIVAS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:background="@drawable/seccion_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="✦" android:textColor="@color/dorado" android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="MISIONES ACTIVAS" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="›" android:textColor="@color/dorado" android:textSize="18sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="6dp"/>

                <LinearLayout android:id="@+id/layoutActivas" android:orientation="vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <TextView android:text="VER TODAS LAS MISIONES  ›"
                    android:textColor="@color/dorado_claro" android:textSize="11sp"
                    android:gravity="center" android:paddingTop="6dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- MISIONES DISPONIBLES -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:background="@drawable/seccion_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="✦" android:textColor="@color/dorado" android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="MISIONES DISPONIBLES" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="›" android:textColor="@color/dorado" android:textSize="18sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="6dp"/>

                <LinearLayout android:id="@+id/layoutDisponibles" android:orientation="vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <Button android:id="@+id/btnAgregar"
                    android:text="＋  NUEVA MISIÓN"
                    android:backgroundTint="@color/boton_bg" android:textColor="@color/dorado"
                    android:textSize="12sp" android:layout_marginTop="6dp"
                    android:layout_width="match_parent" android:layout_height="36dp"/>
            </LinearLayout>

            <!-- HECHIZOS CONOCIDOS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:background="@drawable/seccion_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="✦" android:textColor="@color/dorado" android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="HECHIZOS CONOCIDOS" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="›" android:textColor="@color/dorado" android:textSize="18sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="6dp"/>

                <LinearLayout android:orientation="horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <LinearLayout android:id="@+id/layoutSpells" android:orientation="vertical"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>

                    <LinearLayout android:orientation="vertical" android:gravity="center"
                        android:layout_marginStart="8dp" android:padding="8dp"
                        android:background="@drawable/tomo_bg"
                        android:layout_width="76dp" android:layout_height="wrap_content">
                        <TextView android:text="📖" android:textSize="34sp" android:gravity="center"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="✦  ✦  ✦" android:textColor="@color/dorado"
                            android:textSize="8sp" android:gravity="center" android:layout_marginTop="3dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Tomo\nArcano" android:textColor="@color/dorado_claro"
                            android:textSize="9sp" android:gravity="center" android:fontFamily="serif"
                            android:layout_marginTop="3dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:text="VER TODOS (12)  ›"
                    android:textColor="@color/dorado_claro" android:textSize="11sp"
                    android:gravity="end" android:paddingTop="6dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- TIRADA DE DADOS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
                android:layout_marginBottom="16dp"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:background="@drawable/seccion_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="✦" android:textColor="@color/dorado" android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="TIRADA DE DADOS" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="›" android:textColor="@color/dorado" android:textSize="18sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="6dp"/>

                <LinearLayout android:orientation="horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <!-- IZQ: 6 dados en fila + botón aleatorio -->
                    <LinearLayout android:orientation="vertical"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="62" android:layout_marginEnd="4dp">

                        <LinearLayout android:orientation="horizontal"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <Button android:id="@+id/btnD4" android:text="▲"
                                    android:textSize="12sp" android:textColor="@color/texto"
                                    android:backgroundTint="@color/dado_bg"
                                    android:layout_width="32dp" android:layout_height="32dp" android:padding="0dp"/>
                                <TextView android:text="d4" android:textColor="@color/texto_secundario"
                                    android:textSize="9sp" android:gravity="center"
                                    android:layout_width="32dp" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <Button android:id="@+id/btnD6" android:text="⬡"
                                    android:textSize="12sp" android:textColor="@color/texto"
                                    android:backgroundTint="@color/dado_bg"
                                    android:layout_width="32dp" android:layout_height="32dp" android:padding="0dp"/>
                                <TextView android:text="d6" android:textColor="@color/texto_secundario"
                                    android:textSize="9sp" android:gravity="center"
                                    android:layout_width="32dp" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <Button android:id="@+id/btnD8" android:text="◆"
                                    android:textSize="12sp" android:textColor="@color/texto"
                                    android:backgroundTint="@color/dado_bg"
                                    android:layout_width="32dp" android:layout_height="32dp" android:padding="0dp"/>
                                <TextView android:text="d8" android:textColor="@color/texto_secundario"
                                    android:textSize="9sp" android:gravity="center"
                                    android:layout_width="32dp" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <Button android:id="@+id/btnD10" android:text="⬟"
                                    android:textSize="12sp" android:textColor="@color/texto"
                                    android:backgroundTint="@color/dado_bg"
                                    android:layout_width="32dp" android:layout_height="32dp" android:padding="0dp"/>
                                <TextView android:text="d10" android:textColor="@color/texto_secundario"
                                    android:textSize="9sp" android:gravity="center"
                                    android:layout_width="32dp" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <Button android:id="@+id/btnD12" android:text="⬡"
                                    android:textSize="12sp" android:textColor="@color/texto"
                                    android:backgroundTint="@color/dado_bg"
                                    android:layout_width="32dp" android:layout_height="32dp" android:padding="0dp"/>
                                <TextView android:text="d12" android:textColor="@color/texto_secundario"
                                    android:textSize="9sp" android:gravity="center"
                                    android:layout_width="32dp" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <LinearLayout android:orientation="vertical" android:gravity="center"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                                <Button android:id="@+id/btnD20" android:text="⬠"
                                    android:textSize="12sp" android:textColor="@color/dorado"
                                    android:backgroundTint="@color/dado_bg"
                                    android:layout_width="32dp" android:layout_height="32dp" android:padding="0dp"/>
                                <TextView android:text="d20" android:textColor="@color/dorado"
                                    android:textSize="9sp" android:gravity="center"
                                    android:layout_width="32dp" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </LinearLayout>

                        <Button android:id="@+id/btnAleatorio"
                            android:text="🎲  TIRAR DADO ALEATORIO"
                            android:backgroundTint="@color/boton_bg" android:textColor="@color/dorado"
                            android:textSize="10sp"
                            android:layout_width="match_parent" android:layout_height="32dp"/>
                    </LinearLayout>

                    <!-- DER -->
                    <LinearLayout android:orientation="vertical"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="38">

                        <LinearLayout android:orientation="vertical" android:gravity="center"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:background="@drawable/stat_bg"
                            android:layout_width="match_parent"
                            android:layout_height="0dp" android:layout_weight="1">
                            <TextView android:text="RESULTADO" android:textColor="@color/dorado_claro"
                                android:textSize="8sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/txtResultado" android:text="-"
                                android:textColor="@color/dorado" android:textSize="26sp" android:textStyle="bold"
                                android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/txtTipoDado" android:text=""
                                android:textColor="@color/texto_secundario" android:textSize="10sp"
                                android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <Button android:id="@+id/btnHistorial"
                            android:text="🕐  HISTORIAL"
                            android:backgroundTint="@color/boton_bg" android:textColor="@color/dorado_claro"
                            android:textSize="8sp" android:layout_marginTop="4dp"
                            android:layout_width="match_parent" android:layout_height="32dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!--  MENU INFERIOR  -->
    <LinearLayout
        android:id="@+id/bottomMenu"
        android:orientation="horizontal"
        android:background="@drawable/seccion_bg"
        android:paddingTop="6dp" android:paddingBottom="6dp"
        android:layout_width="0dp" android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/menuInicio"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="✦" android:textColor="@color/dorado" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="INICIO" android:textColor="@color/dorado" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/menuInventario"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="🎒" android:textColor="@color/texto_secundario" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="INVENTARIO" android:textColor="@color/texto_secundario" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/menuNotas"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="📖" android:textColor="@color/texto_secundario" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="NOTAS" android:textColor="@color/texto_secundario" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/menuAjustes"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="⚙" android:textColor="@color/texto_secundario" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="AJUSTES" android:textColor="@color/texto_secundario" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>